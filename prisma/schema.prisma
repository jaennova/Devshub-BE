generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  password    String
  username    String  @unique
  githubId    String? @unique
  position    String?
  description String?

  photoKey String?

  techStack   String[] @default([])
  socialLinks Json?
  websiteUrl  String?

  isActive   Boolean @default(true)
  isAdmin    Boolean @default(false)
  isVerified Boolean @default(false)

  following              Follow[]                @relation("UserFollowing")
  followers              Follow[]                @relation("UserFollowers")
  posts                  Post[]
  draftPosts             DraftPost[]
  discussions            Discussion[]
  comments               Comment[]
  discussionComments     DiscussionComment[]
  commentLikes           CommentLike[]
  discussionCommentLikes DiscussionCommentLike[]
  likes                  Like[]
  discussionLikes        DiscussionLike[]
  bookmarks              Bookmark[]
  reportsMade            Report[]                @relation("ReportReporter")
  reportsReceived        Report[]                @relation("ReportReportedUser")
  notificationsReceived  Notification[]          @relation("NotificationRecipient")
  notificationsAsActor   Notification[]          @relation("NotificationActor")

  challengesCreated        Challenge[]               @relation("ChallengeCreator")
  challengeSoloEnrollments ChallengeSoloEnrollment[]
  challengeTeamMemberships ChallengeTeamMember[]

  hiddenPosts HiddenPost[]
  hiddenDiscussions HiddenDiscussion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ChallengeMode {
  SOLO
  TEAMS
}

model Challenge {
  id               String        @id @default(cuid())
  creatorId        String
  title            String
  description      String?
  endsAt           DateTime
  mode             ChallengeMode
  /// Texto del premio; null/ vacío = sin premio
  prizeDescription String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  creator         User                      @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  soloEnrollments ChallengeSoloEnrollment[]
  teams           ChallengeTeam[]

  @@index([creatorId])
  @@index([endsAt])
  @@index([mode])
}

/// Participación en retos en modo individual (un usuario = una fila)
model ChallengeSoloEnrollment {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  createdAt   DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

/// Equipo dentro de un reto (modo TEAMS)
model ChallengeTeam {
  id          String   @id @default(cuid())
  challengeId String
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge             @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  members   ChallengeTeamMember[]

  @@index([challengeId])
}

model ChallengeTeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team ChallengeTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
}

model PendingRegistration {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String   @unique
  password    String
  position    String?
  description String?
  techStack   String[] @default([])
  socialLinks Json?
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

model Post {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  description String?
  media       String[] @default([])
  website     String?
  tags        String[] @default([])
  isDraft     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         Like[]
  bookmarks     Bookmark[]
  comments      Comment[]
  notifications Notification[]
  reports       Report[]       @relation("ReportPost")
  hiddenBy      HiddenPost[]

  @@index([authorId])
  @@index([createdAt])
}

model DraftPost {
  id          String   @id @default(cuid())
  authorId    String
  title       String   @default("")
  description String?
  media       String[] @default([])
  website     String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([authorId, updatedAt])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Bookmark {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model HiddenPost {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("PostCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("PostCommentThread")
  likes         CommentLike[]
  notifications Notification[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
}

model Discussion {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  description String?
  tags        String[] @default([])
  isDraft     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author        User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         DiscussionLike[]
  comments      DiscussionComment[]
  notifications Notification[]
  hiddenBy      HiddenDiscussion[]

  @@index([authorId])
  @@index([createdAt])
}

model DiscussionLike {
  userId       String
  discussionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@id([userId, discussionId])
  @@index([discussionId])
}

model DiscussionComment {
  id           String   @id @default(cuid())
  discussionId String
  authorId     String
  parentId     String?
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  discussion    Discussion              @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author        User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        DiscussionComment?      @relation("DiscussionCommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies       DiscussionComment[]     @relation("DiscussionCommentThread")
  likes         DiscussionCommentLike[]
  notifications Notification[]

  @@index([discussionId])
  @@index([authorId])
  @@index([parentId])
}

model DiscussionCommentLike {
  userId              String
  discussionCommentId String
  createdAt           DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussionComment DiscussionComment @relation(fields: [discussionCommentId], references: [id], onDelete: Cascade)

  @@id([userId, discussionCommentId])
  @@index([discussionCommentId])
}

enum NotificationType {
  MENTION
  COMMENT_ON_YOUR_POST
  LIKE_ON_YOUR_POST
  COMMENT_ON_YOUR_DISCUSSION
  LIKE_ON_YOUR_DISCUSSION
  LIKE_ON_YOUR_POST_COMMENT
  REPLY_TO_YOUR_POST_COMMENT
  LIKE_ON_YOUR_DISCUSSION_COMMENT
  REPLY_TO_YOUR_DISCUSSION_COMMENT
  NEW_FOLLOWER
}

model Notification {
  id                  String           @id @default(cuid())
  userId              String
  actorId             String?
  type                NotificationType
  title               String
  preview             String?
  postId              String?
  commentId           String?
  discussionId        String?
  discussionCommentId String?
  metadata            Json?
  read                Boolean          @default(false)
  readAt              DateTime?
  createdAt           DateTime         @default(now())

  recipient         User               @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor             User?              @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  post              Post?              @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment           Comment?           @relation(fields: [commentId], references: [id], onDelete: Cascade)
  discussion        Discussion?        @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  discussionComment DiscussionComment? @relation(fields: [discussionCommentId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model Report {
  id             String  @id @default(cuid())
  reporterId     String
  postId         String?
  reportedUserId String?

  typeReport     String
  title          String
  description    String?
  image          String?
  url            String?
  emailToContact String?

  reporter     User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  post         Post? @relation("ReportPost", fields: [postId], references: [id], onDelete: Cascade)
  reportedUser User? @relation("ReportReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([reporterId])
  @@index([postId])
  @@index([reportedUserId])
  @@index([createdAt])
}

model HiddenDiscussion {
  userId       String
  discussionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@id([userId, discussionId])
  @@index([discussionId])
}
